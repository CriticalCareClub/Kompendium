  pages = {378--385},
  doi = {10.1016/j.resuscitation.2010.12.014},
  url = {http://dx.doi.org/10.1016/j.resuscitation.2010.12.014},
  abstract = {Prior studies describe airway management by single EMS agencies, regions
	or states. We sought to characterize out-of-hospital airway management
	interventions, outcomes and complications across the United States.Using
	the 2008 National Emergency Medical Services Information System (NEMSIS)
	Public-Release Data Set containing data from 16 states, we identified
