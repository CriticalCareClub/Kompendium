@ARTICLE{Wang2011,
  author = {Wang, Henry E. and Mann, N Clay and Mears, Gregory and Jacobson,
	Karen and Yealy, Donald M.},
  title = {Out-of-hospital airway management in the United States.},
  year = {2011},
  language = {english},
  volume = {82},
  number = {4},
