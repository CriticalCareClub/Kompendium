@ARTICLE{Allison2004,
  author = {K. Allison and K. Porter},
  title = {Consensus on the prehospital approach to burns patient management.},
  year = {2004},
  language = {english},
  volume = {21},
  number = {1},
  month = {Jan},
  pages = {112--114},
  abstract = {Burns patients form a large group of trauma patients cared for by
	first aiders, ambulance staff, nurses, and doctors before reaching
	specialist care in hospital. Guidance for these important carers
	is often poor or confused and this engenders anxiety and detracts
	from optimal patient care. This paper outlines nine key steps in
	the initial management of burn patients in the prehospital environment
	based on current available evidence and a consensus of specialists
	from all disciplines caring for burns patients. The basis of care
	should be that simple things should always be performed well.},
