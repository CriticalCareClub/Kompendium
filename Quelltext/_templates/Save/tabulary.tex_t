\begin{savenotes}\sffamily\small\begin{ParWide}\sphinxattablestart
<% if table.align -%>
  <%- if table.align == 'center' -%>
  \centering
  <%- elif table.align == 'left' -%>
  \raggedright
  <%- else -%>
  \raggedleft
  <%- endif %>
<%- else -%>
  \centering
<%- endif %>
<% if table.caption -%>
\sphinxcapstartof{table}
\sphinxthecaptionisattop
\sphinxcaption{<%= ''.join(table.caption) %>}<%= labels %>
\sphinxaftertopcaption
<% elif labels -%>
\phantomsection<%= labels %>\nobreak
<% endif -%>
\renewcommand{\hline}{\addlinespace}
\begin{tabulary}{\linewidth}[t]<%= table.get_colspec() -%>
\toprule\addlinespace
<%= ''.join(table.header) %>
<%=- ''.join(table.body) %>
\bottomrule
\end{tabulary}
\par
\sphinxattableend\end{ParWide}\end{savenotes}
