	Wedge Pressure; Resuscitation; Retrospective Studies; Sepsis, complications;
	Shock, diagnosis/etiology/metabolism/physiopathology/therapy; Skin
	Temperature; Systole},
  language = {english},
  owner = {grissu},
  pmid = {11303155},
  review = {schock-marker waren sign bei kalter haut vs warme haut},
  timestamp = {2009.05.08},
