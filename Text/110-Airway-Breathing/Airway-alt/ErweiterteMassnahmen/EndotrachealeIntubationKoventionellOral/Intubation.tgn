,"valign":"top","padding":{"top":10,"right":5,"bottom":10,"left":5},"border_color":""}}]],"model":{"rows":[[{"value":"#","cspan":1,"rspan":1,"markup":[1,1]},{"value":"**Assistenz**\n","cspan":1,"rspan":1,"markup":[1,14]},{"value":"**Durchführender**","cspan":1,"rspan":1,"markup":[1,18]}],[{"value":"\n**1**","cspan":1,"rspan":1,"markup":[1,6]},{"value":"**Narkoseeinleitung**\n\nVon jetzt an besteht ein sehr hohes Risiko \ndass es zu Erbrechen\nkommen kann, \nggfs. muss sofort abgesaugt werden! \n\nDer Wirkeintritt derMedikamente wird abgewartet.\n","cspan":2,"rspan":1,"markup":[1,189]},{"value":"","cspan":-1,"rspan":1,"markup":[]}],[{"value":"1.a","cspan":1,"rspan":1,"markup":[1,3]},{"value":"**Injektion** der Medikamente \nin der festgelegten Reihenfolge und Dosierung","cspan":1,"rspan":1,"markup":[1,76]},{"value":"Achten auf Wirkung der Medikamente und Zeit","cspan":1,"rspan":1,"markup":[1,43]}],[{"value":"**2**","cspan":1,"rspan":1,"markup":[1,5]},{"value":"**Abwarten** des Wirkeintritts der Medikamente","cspan":2,"rspan":1,"markup":[1,46]},{"value":"","cspan":-1,"rspan":1,"markup":[]}],[{"value":"**3**","cspan":1,"rspan":1,"markup":[0,5]},{"value":"","cspan":1,"rspan":1,"markup":[]},{"value":"Anweisung *\"Beginn Intubation\"*","cspan":1,"rspan":1,"markup":[1,31]}],[{"value":"**4**","cspan":1,"rspan":1,"markup":[0,5]},{"value":"**Laryngoskop zureichen**: in die *linke (!)* Hand [317]_","cspan":1,"rspan":1,"markup":[1,57]},{"value":"","cspan":1,"rspan":1,"markup":[]}],[{"value":"**5**","cspan":1,"rspan":1,"markup":[0,5]},{"value":"","cspan":1,"rspan":1,"markup":[]},{"value":"\nEvtl. **Krikoiddruck**: \n\nAnweisung *"Kehlkopfdruck"* ("Krikoiddruck")","cspan":1,"rspan":1,"markup":[1,71]}],[{"value":"5.a","cspan":1,"rspan":1,"markup":[1,3]},{"value":"Auf Anweisung: Krikoiddruck durchführen","cspan":1,"rspan":1,"markup":[1,39]},{"value":"","cspan":1,"rspan":1,"markup":[]}],[{"value":"**6**","cspan":1,"rspan":1,"markup":[0,5]},{"value":"**Tubus zureichen**: in die *rechte (!)* Hand","cspan":1,"rspan":1,"markup":[1,45]},{"value":"","cspan":1,"rspan":1,"markup":[]}],[{"value":"**7**","cspan":1,"rspan":1,"markup":[0,5]},{"value":"Auf Anweisung absaugen","cspan":1,"rspan":1,"markup":[1,22]},{"value":"","cspan":1,"rspan":1,"markup":[]}],[{"value":"**8**","cspan":1,"rspan":1,"markup":[0,5]},{"value":"","cspan":1,"rspan":1,"markup":[]},{"value":"**Einführen des Tubus** \nbis die zwischen die Stimmbänder durchdringt","cspan":1,"rspan":1,"markup":[1,69]}],[{"value":"**9**","cspan":1,"rspan":1,"markup":[0,5]},{"value":"","cspan":1,"rspan":1,"markup":[]},{"value":"Anweisung: **"Führungsdraht entfernen!"**","cspan":1,"rspan":1,"markup":[1,41]}],[{"value":"**10**","cspan":1,"rspan":1,"markup":[0,6]},{"value":"Wenn die Tubusspitze durch die Stimmritzen durchgetreten ist \nmuss der Mandrin entfernt werden um Verletzungen zu vermeiden. \n\nDer **Führungsdraht wird herausgezogen**, \ndabei am Tubus-Konus Gegenhalten um ein Verrutschen des Tubus zu verhindern, \nda dieser ragt nur knapp in die Luftröhre hinein!","cspan":1,"rspan":1,"markup":[1,297]},{"value":"","cspan":1,"rspan":1,"markup":[]}],[{"value":"**11**","cspan":1,"rspan":1,"markup":[0,6]},{"value":"","cspan":1,"rspan":1,"markup":[]},{"value":"","cspan":1,"rspan":1,"markup":[]}],[{"value":"**12**","cspan":1,"rspan":1,"markup":[0,6]},{"value":"","cspan":1,"rspan":1,"markup":[]},{"value":"Tubus bis zur **bis zu endgültigen Tiefe einführen** \nund vorübergehend **manuell fixieren**","cspan":1,"rspan":1,"markup":[1,92]}],[{"value":"**13**","cspan":1,"rspan":1,"markup":[0,6]},{"value":"","cspan":1,"rspan":1,"markup":[]},{"value":"Anweisung **"Cuffen"**","cspan":1,"rspan":1,"markup":[1,22]}],[{"value":"**14**","cspan":1,"rspan":1,"markup":[0,6]},{"value":"**Cuffen**: Cuff mit luftgefüllter Spritze Cuff aufblasen","cspan":1,"rspan":1,"markup":[1,57]},{"value":"","cspan":1,"rspan":1,"markup":[]}],[{"value":"**15**","cspan":1,"rspan":1,"markup":[0,6]},{"value":"*Stethoskop* dem Durchführenden in die Ohren klemmen","cspan":1,"rspan":1,"markup":[1,52]},{"value":"","cspan":1,"rspan":1,"markup":[]}],[{"value":"**16**","cspan":1,"rspan":1,"markup":[0,6]},{"value":"Beatmungsmaske vom Beatmungsbeutel trennen","cspan":1,"rspan":1,"markup":[1,42]},{"value":"","cspan":1,"rspan":1,"markup":[]}],[{"value":"**17**","cspan":1,"rspan":1,"markup":[0,6]},{"value":"*Beatmungsbeutel* an Tubus anschließen und halten","cspan":1,"rspan":1,"markup":[1,49]},{"value":"","cspan":1,"rspan":1,"markup":[]}],[{"value":"**18**","cspan":1,"rspan":1,"markup":[0,6]},{"value":"Auf Anweisung Atemhub verabreichen lassen \n(mind. 3 Atemhübe in Summe)","cspan":1,"rspan":1,"markup":[1,70]},{"value":"*Lagekontrolle* mittels Auskulatation: \n\n\n- Magengegend und \n\n- beide Lungenflügel auskultieren, \n\ndabei jeweils Anweisung *"Atemhub"*","cspan":1,"rspan":1,"markup":[1,134]}],[{"value":"**19**","cspan":1,"rspan":1,"markup":[0,6]},{"value":"","cspan":1,"rspan":1,"markup":[]},{"value":"Beatmungsbeutel übernehmen","cspan":1,"rspan":1,"markup":[1,26]}],[{"value":"**20**","cspan":1,"rspan":1,"markup":[0,6]},{"value":"Einführen des **Beißkeils** oder des Guedel-Tubus","cspan":1,"rspan":1,"markup":[1,49]},{"value":"","cspan":1,"rspan":1,"markup":[]}],[{"value":"**21**","cspan":1,"rspan":1,"markup":[0,6]},{"value":"**Fixierung** des Tubus und des Beißschutzes mittels \nMullbinde, \nKlebestreifen \noder speziellen Fixationsmaterialien","cspan":1,"rspan":1,"markup":[1,117]},{"value":"","cspan":1,"rspan":1,"markup":[]}],[{"value":"","cspan":1,"rspan":1,"markup":[]},{"value":"Ggfs. Beatmungsgerät einstellen und anschließen","cspan":1,"rspan":1,"markup":[1,47]},{"value":"","cspan":1,"rspan":1,"markup":[]}],[{"value":"","cspan":1,"rspan":1,"markup":[]},{"value":"","cspan":1,"rspan":1,"markup":[]},{"value":"","cspan":1,"rspan":1,"markup":[]}],[{"value":"","cspan":1,"rspan":1,"markup":[]},{"value":"","cspan":1,"rspan":1,"markup":[]},{"value":"","cspan":1,"rspan":1,"markup":[]}],[{"value":"","cspan":1,"rspan":1,"