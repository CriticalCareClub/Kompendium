@ARTICLE{Peiris2009,
  author = {J. S Malik Peiris and Leo L M Poon and Yi Guan},
  title = {Emergence of a novel swine-origin influenza A virus (S-OIV) H1N1
	virus in humans.},
  year = {2009},
  language = {english},
  volume = {45},
