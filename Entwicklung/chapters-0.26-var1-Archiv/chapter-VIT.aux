\@writefile{lofazit}{\defcounter {refsection}{0}\relax }\@writefile{lofazit}{\contentsline {section}{Mittels Osmose und Diffusion verteilt der K\IeC {\"o}rper das Wasser.}{358}{paragraph*.803}}
\@writefile{lofazit}{\defcounter {refsection}{0}\relax }\@writefile{lofazit}{\contentsline {section}{Die \EE  {Elektrolyte} haben einen gro\IeC {\ss }en Einfluss auf die Wasserverteilung: Nur wenn die Elektrolyte richtig verteilt sind, kann das Wasser richtig verteilt werden.}{358}{paragraph*.803}}
