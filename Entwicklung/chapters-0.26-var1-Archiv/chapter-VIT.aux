\@writefile{lofazit}{\defcounter {refsection}{0}\relax }\@writefile{lofazit}{\contentsline {section}{Besonders die \EE  {Atmung} und der \EE  {Stoffwechsel} k\IeC {\"o}nnen dem S\IeC {\"a}ure-Basen-Haushalt Streiche spielen: \newline  Wer zu wenig atmet wird sauer. \newline  Wer zu viel atmet wird basisch und sp\IeC {\"u}rt ein Kribbeln in den Fingern. \newline  Wer Probleme mit dem Stoffwechsel hat kann auch sauer oder basisch werden.}{358}{paragraph*.803}}
