  url = {http://dx.doi.org/10.1007/s00134-002-1290-x},
  abstract = {Verification of endotracheal tube placement is of vital importance,
	since unrecognized esophageal intubation can be rapidly fatal (death,
	brain damage). The aim of our study was to compare three different
	methods for immediate confirmation of tube placement: auscultation,
	capnometry and capnography in emergency conditions in the prehospital
	setting.Prospective study in the prehospital setting.All adult patients
